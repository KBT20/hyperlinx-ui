[32m+[m[32m## Evidence Doctrine[m
[32m+[m
[32m+[m[32mExternal APIs and files provide evidence.[m
[32m+[m
[32m+[m[32mEvidence is not authority. Evidence supports authority.[m
[32m+[m
[32m+[m[32mThe DAL kernel synthesizes truth through governed objects and transitions. Conflicting evidence must be preserved, not overwritten.[m
[32m+[m
[32m+[m[32m## Evidence Sources[m
[32m+[m
[32m+[m[32mEvidence may come from:[m
[32m+[m
[32m+[m[32m- Customer route file.[m
[32m+[m[32m- Endpoint CSV.[m
[32m+[m[32m- KML/KMZ.[m
[32m+[m[32m- GeoJSON.[m
[32m+[m[32m- Shapefile.[m
[32m+[m[32m- DOT GIS.[m
[32m+[m[32m- OSRM.[m
[32m+[m[32m- GraphHopper.[m
[32m+[m[32m- OpenRouteService.[m
[32m+[m[32m- Power dataset.[m
[32m+[m[32m- Parcel dataset.[m
[32m+[m[32m- Data center dataset.[m
[32m+[m[32m- Human engineering review.[m
[32m+[m[32m- Field validation.[m
[32m+[m[32m- Permit record.[m
[32m+[m
[32m+[m[32m## CorridorEvidence Fields[m
[32m+[m
[32m+[m[32m```ts[m
[32m+[m[32m{[m
[32m+[m[32m  evidenceId;[m
[32m+[m[32m  sourceType;[m
[32m+[m[32m  sourceName;[m
[32m+[m[32m  collectedAt;[m
[32m+[m[32m  confidence;[m
[32m+[m[32m  entityType;[m
